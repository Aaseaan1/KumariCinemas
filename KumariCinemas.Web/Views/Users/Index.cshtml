@model IEnumerable<KumariCinemas.Web.Models.AppUser>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Users</h1>
    <a class="btn btn-primary" asp-action="Create">Add User</a>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Username</th>
            <th>Address</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Username</td>
            <td>@user.Address</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@user.UserId">Details</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.UserId">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@user.UserId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
