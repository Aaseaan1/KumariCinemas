@{
    ViewData["Title"] = "Home Page";
}

<div class="d-flex flex-column justify-content-center align-items-center min-vh-100" style="margin-top:-10vh;">
    <div class="text-center mb-4">
        <h1 class="display-5">Kumari Cinemas</h1>
        <p class="lead">Welcome to Kumari Cinemas! Manage Your Movies, Showtimes, Users, And Bookings All In One Place.</p>
    </div>
    <div class="row g-3 justify-content-center w-100" style="max-width: 900px;">
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100 py-5 home-action-btn" asp-controller="Movies" asp-action="Index">View Movies</a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100 py-5 home-action-btn" asp-controller="Showtimes" asp-action="Index">View Showtimes</a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100 py-5 home-action-btn" asp-controller="Users" asp-action="Index">Manage Users</a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100 py-5 home-action-btn" asp-controller="Halls" asp-action="Index">Manage Halls</a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100 py-5 home-action-btn" asp-controller="Bookings" asp-action="Index">Manage Bookings</a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100 py-5 home-action-btn" asp-controller="Reports" asp-action="Index">View Reports</a>
        </div>
    </div>
</div>
