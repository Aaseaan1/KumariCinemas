@model KumariCinemas.Web.Models.Showtime

@{
    ViewData["Title"] = "Delete Showtime";
}

<h1>Delete Showtime</h1>
<p class="text-danger">Are you sure you want to delete this showtime?</p>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <p><strong>Movie:</strong> @Model.Movie?.Title</p>
        <p><strong>Hall:</strong> @Model.Hall?.TheaterCity</p>
        <p><strong>Date:</strong> @Model.ShowDate.ToString("yyyy-MM-dd")</p>
        <p><strong>Time Slot:</strong> @Model.ShowTimeName</p>
        <p><strong>Ticket Price:</strong> @Model.TicketPrice</p>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ShowTimeId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
