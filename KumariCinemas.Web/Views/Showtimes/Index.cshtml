@model IEnumerable<KumariCinemas.Web.Models.Showtime>

@{
    ViewData["Title"] = "Showtimes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Showtimes</h1>
    <a class="btn btn-primary" asp-action="Create">Add Showtime</a>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Movie</th>
            <th>Date</th>
            <th>Time Slot</th>
            <th>Hall</th>
            <th>Ticket Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var showtime in Model)
    {
        <tr>
            <td>@showtime.Movie?.Title</td>
            <td>@showtime.ShowDate.ToString("yyyy-MM-dd")</td>
            <td>@showtime.ShowTimeName</td>
            <td>@showtime.Hall?.TheaterCity</td>
            <td>@showtime.TicketPrice</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@showtime.ShowTimeId">Details</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@showtime.ShowTimeId">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@showtime.ShowTimeId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
