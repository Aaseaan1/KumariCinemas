@model KumariCinemas.Web.Models.Showtime

@{
    ViewData["Title"] = "Add Showtime";
}

<h1>Add Showtime</h1>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="MovieId" class="form-label text-white">Movie</label>
        <select asp-for="MovieId" asp-items="ViewBag.Movies" class="form-select">
            <option value="">Select movie</option>
        </select>
        <span asp-validation-for="MovieId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="HallId" class="form-label text-white">Hall</label>
        <select asp-for="HallId" asp-items="ViewBag.Halls" class="form-select">
            <option value="">Select hall</option>
        </select>
        <span asp-validation-for="HallId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ShowDate" class="form-label text-white"></label>
        <input asp-for="ShowDate" type="date" class="form-control" />
        <span asp-validation-for="ShowDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ShowTimeName" class="form-label text-white">Time Slot</label>
        <input asp-for="ShowTimeName" class="form-control" placeholder="Morning / Afternoon / Evening" />
        <span asp-validation-for="ShowTimeName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TicketPrice" class="form-label text-white"></label>
        <input asp-for="TicketPrice" class="form-control" />
        <span asp-validation-for="TicketPrice" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

<style>
    .form-select, .form-control {
        background-color: #222 !important;
        color: #fff !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
