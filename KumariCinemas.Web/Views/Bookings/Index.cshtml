@model IEnumerable<KumariCinemas.Web.Models.Ticket>

@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Bookings</h1>
    <a class="btn btn-primary" asp-controller="Bookings" asp-action="Create">New Booking</a>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ticket ID</th>
            <th>User</th>
            <th>Movie</th>
            <th>Show Date</th>
            <th>Hall</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var ticket in Model)
    {
        <tr>
            <td>@ticket.TicketId</td>
            <td>@ticket.User?.Username</td>
            <td>@ticket.Showtime?.Movie?.Title</td>
            <td>@ticket.Showtime?.ShowDate.ToString("yyyy-MM-dd")</td>
            <td>@ticket.Showtime?.Hall?.TheaterCity</td>
            <td>@ticket.BookingStatus</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@ticket.TicketId">Details</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@ticket.TicketId">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@ticket.TicketId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
