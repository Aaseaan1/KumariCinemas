@model KumariCinemas.Web.Models.Ticket

@{
    ViewData["Title"] = "Delete Booking";
}

<h1>Delete Booking</h1>
<p class="text-danger">Are you sure you want to delete this booking?</p>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <p><strong>Ticket ID:</strong> @Model.TicketId</p>
        <p><strong>User:</strong> @Model.User?.Username</p>
        <p><strong>Movie:</strong> @Model.Showtime?.Movie?.Title</p>
        <p><strong>Hall:</strong> @Model.Showtime?.Hall?.TheaterCity</p>
        <p><strong>Show Date:</strong> @Model.Showtime?.ShowDate.ToString("yyyy-MM-dd")</p>
        <p><strong>Status:</strong> @Model.BookingStatus</p>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TicketId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>


