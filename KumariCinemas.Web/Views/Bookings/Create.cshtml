@model KumariCinemas.Web.Models.CreateTicketViewModel

@{
    ViewData["Title"] = "Create Booking";
}

<h1>Create Booking</h1>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="UserId" class="form-label text-white"></label>
        <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select">
            <option value="">Select user</option>
        </select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ShowtimeId" class="form-label text-white"></label>
        <select asp-for="ShowtimeId" asp-items="ViewBag.Showtimes" class="form-select">
            <option value="">Select showtime</option>
        </select>
        <span asp-validation-for="ShowtimeId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Book Ticket</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>

<style>
    .form-select {
        background-color: #222 !important;
        color: #fff !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


