@model KumariCinemas.Web.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<h1>Delete Movie</h1>
<p class="text-danger">Are you sure you want to delete this movie?</p>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <p><strong>Title:</strong> @Model.Title</p>
        <p><strong>Language:</strong> @Model.Language</p>
        <p><strong>Genre:</strong> @Model.Genre</p>
        <p><strong>Duration:</strong> @Model.Duration</p>
        <p><strong>Release Date:</strong> @Model.ReleaseDate.ToString("yyyy-MM-dd")</p>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="MovieId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
