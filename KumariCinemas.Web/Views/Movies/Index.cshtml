@model IEnumerable<KumariCinemas.Web.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Movies</h1>
    <a class="btn btn-primary" asp-action="Create">Add Movie</a>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Language</th>
            <th>Genre</th>
            <th>Duration</th>
            <th>Release Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var movie in Model)
    {
        <tr>
            <td>@movie.Title</td>
            <td>@movie.Language</td>
            <td>@movie.Genre</td>
            <td>@movie.Duration</td>
            <td>@movie.ReleaseDate.ToString("yyyy-MM-dd")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@movie.MovieId">Details</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@movie.MovieId">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@movie.MovieId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
