@model KumariCinemas.Web.Models.Movie

@{
    ViewData["Title"] = "Edit Movie";
}

<h1>Edit Movie</h1>

<form asp-action="Edit" method="post" class="mt-3 edit-movie-form">
    <input type="hidden" asp-for="MovieId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
           <label asp-for="Title" class="form-label" style="color:white;"></label>
           <input asp-for="Title" class="form-control" style="color:white;background-color:#222;" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
           <label asp-for="Language" class="form-label" style="color:white;"></label>
           <input asp-for="Language" class="form-control" style="color:white;background-color:#222;" />
        <span asp-validation-for="Language" class="text-danger"></span>
    </div>

    <div class="mb-3">
           <label asp-for="Genre" class="form-label" style="color:white;"></label>
           <input asp-for="Genre" class="form-control" style="color:white;background-color:#222;" />
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>

    <div class="mb-3">
           <label asp-for="Duration" class="form-label" style="color:white;"></label>
           <input asp-for="Duration" class="form-control" style="color:white;background-color:#222;" />
        <span asp-validation-for="Duration" class="text-danger"></span>
    </div>

    <div class="mb-3">
           <label asp-for="ReleaseDate" class="form-label" style="color:white;"></label>
           <input asp-for="ReleaseDate" type="date" class="form-control" style="color:white;background-color:#222;" />
        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
