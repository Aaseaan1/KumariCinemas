@model KumariCinemas.Web.Models.Movie

@{
    ViewData["Title"] = "Add Movie";
}

<h1 class="text-white">Add Movie</h1>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label text-white"></label>
        <input asp-for="Title" class="form-control text-white" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Language" class="form-label text-white"></label>
            <input asp-for="Language" class="form-control text-white" />
        <span asp-validation-for="Language" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Genre" class="form-label text-white"></label>
            <input asp-for="Genre" class="form-control text-white" />
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Duration" class="form-label text-white"></label>
            <input asp-for="Duration" class="form-control text-white" />
        <span asp-validation-for="Duration" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ReleaseDate" class="form-label text-white"></label>
            <input asp-for="ReleaseDate" type="date" class="form-control text-white" />
        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
