@model KumariCinemas.Web.Models.TheaterHall

@{
    ViewData["Title"] = "Delete Hall";
}

<h1>Delete Hall</h1>
<p class="text-danger">Are you sure you want to delete this hall?</p>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <p><strong>Theater:</strong> @Model.TheaterName</p>
        <p><strong>City:</strong> @Model.TheaterCity</p>
        <p><strong>Capacity:</strong> @Model.HallCapacity</p>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="HallId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
