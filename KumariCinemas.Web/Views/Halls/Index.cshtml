@model IEnumerable<KumariCinemas.Web.Models.TheaterHall>

@{
    ViewData["Title"] = "Halls";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Halls</h1>
    <a class="btn btn-primary" asp-action="Create">Add Hall</a>
</div>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Theater</th>
            <th>City</th>
            <th>Capacity</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var hall in Model)
    {
        <tr>
            <td>@hall.TheaterName</td>
            <td>@hall.TheaterCity</td>
            <td>@hall.HallCapacity</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@hall.HallId">Details</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@hall.HallId">Edit</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@hall.HallId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
