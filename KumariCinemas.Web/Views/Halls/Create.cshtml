@model KumariCinemas.Web.Models.TheaterHall

@{
    ViewData["Title"] = "Add Hall";
}

<h1>Add Hall</h1>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TheaterName" class="form-label text-white"></label>
        <input asp-for="TheaterName" class="form-control" />
        <span asp-validation-for="TheaterName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TheaterCity" class="form-label text-white"></label>
        <input asp-for="TheaterCity" class="form-control" />
        <span asp-validation-for="TheaterCity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="HallCapacity" class="form-label text-white"></label>
        <input asp-for="HallCapacity" class="form-control" />
        <span asp-validation-for="HallCapacity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

<style>
    .form-control {
        background-color: #222 !important;
        color: #fff !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

